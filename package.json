{
  "name": "ladybug",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "SceneryStack port of the PhET 'Ladybug Motion 2D' simulation. Explore 2D motion, position, velocity, and acceleration using a ladybug on a rotating platform.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenPhysics/LadyBug.git"
  },
  "keywords": [
    "ladybug",
    "simulation",
    "SceneryStack",
    "interactive",
    "physics",
    "kinematics",
    "2D motion",
    "education",
    "pwa"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "check": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "icons": "tsx scripts/generate-icons.ts",
    "clean": "rm -rf dist",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.10.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
